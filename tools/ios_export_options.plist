<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Used by `xcodebuild -exportArchive` to produce an .ipa from the .xcarchive
  `tools/build_ios.sh` builds. Two tokens get sed-substituted at script
  run-time; the committed template carries placeholders so it's safe to ship.

  @TEAM_ID@ — the developer team's 10-char ID (from $IOS_TEAM_ID).

  @METHOD@ — distribution method:
    `app-store-connect` for TestFlight / App Store upload (default), or
    `development` for direct install onto a tethered, dev-registered device
    (selected by tools/build_ios.sh --tethered).

  signingStyle = automatic: Xcode auto-picks the matching profile for the
    team — works as long as the App ID is registered at developer.apple.com.
  stripSwiftSymbols = true: standard for any iOS distribution.
  uploadSymbols = true: ship dSYMs so App Store Connect can symbolicate
    crash reports (no-op for development builds, but harmless).
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>@METHOD@</string>

    <key>teamID</key>
    <string>@TEAM_ID@</string>

    <key>signingStyle</key>
    <string>automatic</string>

    <key>stripSwiftSymbols</key>
    <true/>

    <key>uploadSymbols</key>
    <true/>

    <key>destination</key>
    <string>export</string>
</dict>
</plist>
