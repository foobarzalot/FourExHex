<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <IsPackable>false</IsPackable>
    <RootNamespace>FourExHex.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="xunit" Version="2.6.6" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.6" />
    <PackageReference Include="GodotSharp" Version="4.6.1" />
  </ItemGroup>

  <!--
    Pull in the production source files we want to test.
    HexMap.cs and Main.cs are excluded because they derive from Node2D and
    require the Godot.NET.Sdk source generator to compile.
  -->
  <ItemGroup>
    <Compile Include="..\scripts\HexCoord.cs" Link="scripts\HexCoord.cs" />
    <Compile Include="..\scripts\HexGrid.cs" Link="scripts\HexGrid.cs" />
    <Compile Include="..\scripts\HexTile.cs" Link="scripts\HexTile.cs" />
    <Compile Include="..\scripts\Territory.cs" Link="scripts\Territory.cs" />
    <Compile Include="..\scripts\TerritoryFinder.cs" Link="scripts\TerritoryFinder.cs" />
    <Compile Include="..\scripts\CapitalAssigner.cs" Link="scripts\CapitalAssigner.cs" />
    <Compile Include="..\scripts\Player.cs" Link="scripts\Player.cs" />
    <Compile Include="..\scripts\TurnState.cs" Link="scripts\TurnState.cs" />
    <Compile Include="..\scripts\Treasury.cs" Link="scripts\Treasury.cs" />
    <Compile Include="..\scripts\Unit.cs" Link="scripts\Unit.cs" />
    <Compile Include="..\scripts\PurchaseRules.cs" Link="scripts\PurchaseRules.cs" />
    <Compile Include="..\scripts\DefenseRules.cs" Link="scripts\DefenseRules.cs" />
    <Compile Include="..\scripts\MovementRules.cs" Link="scripts\MovementRules.cs" />
    <Compile Include="..\scripts\TerritoryReconciler.cs" Link="scripts\TerritoryReconciler.cs" />
    <Compile Include="..\scripts\GameStateSnapshot.cs" Link="scripts\GameStateSnapshot.cs" />
    <Compile Include="..\scripts\UndoStack.cs" Link="scripts\UndoStack.cs" />
  </ItemGroup>

</Project>
