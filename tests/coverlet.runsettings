<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <!--
            The test project pulls production sources in via
            <Compile Include="..\scripts\*.cs"> so the code under test
            lives in the test assembly. coverlet excludes the test
            assembly by default; flip that off.
          -->
          <IncludeTestAssembly>true</IncludeTestAssembly>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
