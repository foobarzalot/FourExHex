<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <!--
      Keep the test project's sources AND the Godot-free model library's
      sources out of the main game assembly. The src/** exclude is
      mandatory: without it the Godot SDK glob would also compile the
      moved sources into FourExHex.dll, duplicating every model type
      (CS0436) since the library already defines them. tools/** likewise
      keeps the level-designer CLI's Program out of the game assembly.
    -->
    <DefaultItemExcludes>$(DefaultItemExcludes);tests/**/*;src/**/*;tools/**/*</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="src\FourExHex.Model\FourExHex.Model.csproj" />
    <ProjectReference Include="src\FourExHex.Controller\FourExHex.Controller.csproj" />
    <ProjectReference Include="src\FourExHex.ViewMath\FourExHex.ViewMath.csproj" />
  </ItemGroup>
</Project>
